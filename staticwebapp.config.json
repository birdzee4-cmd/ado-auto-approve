{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",

  "platform": {
    "apiRuntime": "node:18"
  },

  "routes": [
    {
      "route": "/dashboard.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/dashboard",
      "rewrite": "/dashboard.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/userinfo",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/health",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/test-notification",
      "methods": ["POST"],
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/webhook",
      "methods": ["POST"],
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/.auth/login/github",
      "statusCode": 404
    },
    {
      "route": "/.auth/login/twitter",
      "statusCode": 404
    }
  ],

  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/aad?post_login_redirect_uri=/dashboard.html"
    },
    "403": {
      "redirect": "/403.html",
      "statusCode": 302
    }
  },

  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/*.{css,js,svg,png,jpg,ico}"]
  },

  "auth": {
    "rolesSource": "/api/userinfo",
    "identityProviders": {
      "azureActiveDirectory": {
        "registration": {
          "openIdIssuer": "https://login.microsoftonline.com/36f04887-ce29-484c-900e-f23ad3f60b77/v2.0",
          "clientIdSettingName": "AAD_CLIENT_ID",
          "clientSecretSettingName": "AAD_CLIENT_SECRET"
        }
      }
    }
  },

  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Strict-Transport-Security": "max-age=31536000; includeSubDomains"
  },

  "mimeTypes": {
    ".json": "application/json"
  }
}
